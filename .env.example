# API Configuration
VITE_API_URL=/api

# Optional: slug to show at the root URL (e.g. sushi-spot → menu-o8l.pages.dev shows sushi-spot's menu)
# VITE_DEFAULT_SLUG=your-restaurant-slug

# MongoDB Configuration (for serverless functions)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=Cluster0
MONGODB_DB_NAME=restaurant_menu
